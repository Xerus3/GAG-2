local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")

-- Enhanced require function with retry logic
local function retryRequire(module)
    local moduleData = nil
    local attempts = 0
    while not moduleData and attempts < 20 do
        local success, result = pcall(function() return require(module) end)
        if success then
            moduleData = result
        else
            attempts = attempts + 1
            task.wait(0.5) -- Wait for the module to initialize
        end
    end
    return moduleData
end

-- Wait for Folders
local SharedModules = ReplicatedStorage:WaitForChild("SharedModules", 15)
local Networking = SharedModules:WaitForChild("Networking", 15)
local Flags = SharedModules:WaitForChild("Flags", 15)
local StealFlags = Flags:WaitForChild("StealFlags", 15)
local FruitValueCalc = SharedModules:WaitForChild("FruitValueCalc", 15)

-- Use the retry function
local NetworkModule = retryRequire(Networking)
local StealFlagsModule = retryRequire(StealFlags)
local FruitValueCalcModule = retryRequire(FruitValueCalc)

local LocalPlayer = Players.LocalPlayer
local Gardens = workspace:WaitForChild("Gardens", 15)
local PlayerScripts = LocalPlayer:WaitForChild("PlayerScripts", 15)
local Controllers = PlayerScripts:WaitForChild("Controllers", 15)
local PlantLifecycleHandler = Controllers:WaitForChild("PlantLifecycleHandler", 15)

-- Safely get the controller
local PlantCycleModule = retryRequire(PlantLifecycleHandler)

if not NetworkModule or not StealFlagsModule or not PlantCycleModule then
    warn("Failed to load critical modules. Check game loading.")
    return
end

-- Proceed with the rest of your script...

local OwnerPlot
local startTime = tick()
while OwnerPlot == nil and tick() - startTime < 30 do
    task.wait(0.1)
    for _, plot in pairs(Gardens:GetChildren()) do
        if plot and plot:GetAttribute("Owner") == LocalPlayer.Name then
            OwnerPlot = plot
            break
        end
    end
end

if not OwnerPlot then return end

local function canSteal(player)
    if not player then return false end
    local suc, result = pcall(function() return player:GetAttribute("IsInOwnGarden") end)
    return suc and result or false
end

local function teleportto(hrp, startCFrame, targetCFrame, speed)
    local distance = (targetCFrame.Position - startCFrame.Position).Magnitude
    local duration = distance / speed
    local con
    local elp = 0
    con = RunService.RenderStepped:Connect(function(dt)
        elp = elp + dt
        if elp >= duration then
            if hrp then hrp.CFrame = targetCFrame end
            if con then con:Disconnect() end
            return
        end
        if hrp then hrp.CFrame = startCFrame:Lerp(targetCFrame, elp / duration) end
    end)
    local waitStart = tick()
    while con.Connected and tick() - waitStart < duration + 2 do task.wait() end
    if con.Connected then con:Disconnect() end
end

local function isNightTime()
    return Night and Night:IsA("BoolValue") and Night.Value == true
end

local function getDecay(model)
    local success, Entries = pcall(function() return PlantCycleModule:GetActiveEntries() end)
    if not success or not Entries then return 0 end
    for plantid, planttable in pairs(Entries) do
        if planttable.Model == model then
            local a, b = string.match(plantid, "^(%d+)_(.+)$")
            local decaySuccess, decay = pcall(function() return PlantCycleModule:GetDecayAlpha(tonumber(a), b) end)
            if decaySuccess then return decay or 0 end
        end
    end
    return 0
end

local function getBestPlant()
    local best, bestnumber = nil, -1
    for _, plot in pairs(Gardens:GetChildren()) do
        local Plants = plot:FindFirstChild("Plants")
        if Plants then
            for _, model in pairs(Plants:GetChildren()) do
                local Fruits = model:FindFirstChild("Fruits")
                if Fruits then
                    for _, fruit in pairs(Fruits:GetChildren()) do
                        local seedName = model:GetAttribute("SeedName") or model:GetAttribute("CorePartName")
                        if seedName and StealFlagsModule.IsPlantStealable(seedName) then
                            local targetplayer = Players:GetPlayerByUserId(tonumber(model:GetAttribute("UserId") or 0))
                            if targetplayer and not canSteal(targetplayer) then
                                local val = FruitValueCalcModule(seedName, fruit:GetAttribute("SizeMulti") or 1, fruit:GetAttribute("Mutation") or "", LocalPlayer, getDecay(model))
                                if val and val > bestnumber then bestnumber = val; best = model end
                            end
                        end
                    end
                end
            end
        end
    end
    return best, bestnumber
end

local function performSteal(model)
    if not isNightTime() then return end
    local ownerId, plantId = tonumber(model:GetAttribute("UserId")), model:GetAttribute("PlantId")
    local fruitId = model:GetAttribute("FruitId") or ""
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    local oldPos = OwnerPlot:FindFirstChild("PlotSizeReference").CFrame
    local target = model:FindFirstChildWhichIsA("BasePart").CFrame + Vector3.new(0, 3, 0)
    
    teleportto(hrp, oldPos, target, 30)
    task.wait(1)
    if NetworkModule.Steal.BeginSteal then NetworkModule.Steal.BeginSteal:Fire(ownerId, plantId, fruitId) end
    if NetworkModule.Steal.CompleteSteal then NetworkModule.Steal.CompleteSteal:Fire() end
    task.wait(1)
    teleportto(hrp, target, oldPos, 30)
end

-- MAIN LOOP: Runs only while the Toggle is ON
while _G.Auto.Steal do
    local best = getBestPlant()
    if best then performSteal(best) end
    task.wait(1)
end
